# ============================================================================
# Agent Platform -- Environment Variables
# Copy to .env and customize for your environment
# ============================================================================

# ── Service ────────────────────────────────────────────────────────────
SERVICE_NAME=agent-platform
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# ── Database (Postgres + pgvector) ─────────────────────────────────────
DATABASE_URL=postgresql://agent_platform:agent_platform@localhost:5432/agent_platform

# ── Redis ──────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── MinIO ──────────────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false

# ── LLM Runtime ───────────────────────────────────────────────────────
LLM_PRIMARY_URL=http://localhost:11434/v1
LLM_FALLBACK_URL=http://localhost:8080/v1
LLM_MODEL=llama3.1:8b

# ── Observability ──────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_ENABLED=true

# ── Auth ───────────────────────────────────────────────────────────────
JWT_SECRET=dev-secret-change-in-production
JWT_ALGORITHM=HS256

# ── Service URLs (internal) ───────────────────────────────────────────
AGENT_ENGINE_URL=http://localhost:8003
DOCUMENT_SERVICE_URL=http://localhost:8001
CACHE_SERVICE_URL=http://localhost:8002
COST_TRACKER_URL=http://localhost:8004
