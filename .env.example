# ============================================================================
# Agent Platform -- Environment Variables
# Copy to .env and customize for your environment
#
# NOTE: Host ports use 20xxx range to avoid conflicts with other apps.
# Inside DevContainer, use standard ports (services communicate by name).
# ============================================================================

# ── Service ────────────────────────────────────────────────────────────
SERVICE_NAME=agent-platform
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# ── Database (Postgres + pgvector) ─────────────────────────────────────
# Inside DevContainer: postgresql://agent_platform:agent_platform@postgres:5432/agent_platform
# From host machine:
DATABASE_URL=postgresql://agent_platform:agent_platform@localhost:20432/agent_platform

# ── Redis ──────────────────────────────────────────────────────────────
# Inside DevContainer: redis://redis:6379/0
# From host machine:
REDIS_URL=redis://localhost:20379/0

# ── MinIO ──────────────────────────────────────────────────────────────
# Inside DevContainer: minio:9000
# From host machine:
MINIO_ENDPOINT=localhost:20900
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false

# ── LLM Runtime ───────────────────────────────────────────────────────
# Inside DevContainer: http://ollama:11434/v1
# From host machine:
LLM_PRIMARY_URL=http://localhost:20434/v1
LLM_FALLBACK_URL=http://localhost:8080/v1
LLM_MODEL=llama3.1:8b

# ── Observability ──────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_ENABLED=true

# ── Auth ───────────────────────────────────────────────────────────────
JWT_SECRET=dev-secret-change-in-production
JWT_ALGORITHM=HS256

# ── Service URLs (internal, used between services) ───────────────────
AGENT_ENGINE_URL=http://localhost:8003
DOCUMENT_SERVICE_URL=http://localhost:8001
CACHE_SERVICE_URL=http://localhost:8002
COST_TRACKER_URL=http://localhost:8004
