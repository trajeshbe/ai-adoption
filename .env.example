# ============================================================================
# AI Agent Platform -- Environment Variables
# Copy to .env and customize for your deployment
#
# TWO DEPLOYMENT MODES:
#   1. docker compose up          -- Full standalone (GCP/Azure/AWS)
#   2. DevContainer + host        -- Local dev (services run natively)
# ============================================================================

# ── LLM Model ───────────────────────────────────────────────────────────
LLM_MODEL=qwen2.5:1.5b
# Other options: llama3.1:8b, mistral:7b, phi3:mini, gemma2:2b

# ── Frontend (BUILD-TIME variable -- set before docker compose build) ───
# Set to the PUBLIC IP/domain of your server
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:8050/graphql
# GCP:   http://<EXTERNAL_IP>:8050/graphql
# Azure: http://<PUBLIC_IP>:8050/graphql

# ── Port Map (docker compose) ──────────────────────────────────────────
FRONTEND_PORT=8055
GATEWAY_PORT=8050
AGENT_ENGINE_PORT=8053
DOC_SERVICE_PORT=8051
CACHE_SERVICE_PORT=8052
COST_TRACKER_PORT=8054
POSTGRES_PORT=5432
REDIS_PORT=6379
REDIS_UI_PORT=8001
MINIO_API_PORT=9000
MINIO_UI_PORT=9001
OLLAMA_PORT=11434

# ── Security (CHANGE THESE IN PRODUCTION) ───────────────────────────────
JWT_SECRET=change-me-in-production
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ── Debug Mode ──────────────────────────────────────────────────────────
DEBUG=false

# ============================================================================
# LOCAL DEV OVERRIDES (when running services natively, not in Docker)
# ============================================================================
# SERVICE_NAME=agent-platform
# ENVIRONMENT=development
# DEBUG=true
# LOG_LEVEL=INFO
# DATABASE_URL=postgresql://agent_platform:agent_platform@localhost:20432/agent_platform
# REDIS_URL=redis://localhost:20379/0
# MINIO_ENDPOINT=localhost:20900
# LLM_PRIMARY_URL=http://localhost:20434/v1
# LLM_FALLBACK_URL=http://localhost:8080/v1
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# AGENT_ENGINE_URL=http://localhost:8003
# DOCUMENT_SERVICE_URL=http://localhost:8001
# CACHE_SERVICE_URL=http://localhost:8002
# COST_TRACKER_URL=http://localhost:8004
